    },
    {
      "parameters": {
        "jsCode": "let text = $json.output;\n\n// Remove Gemini markdown wrappers\ntext = text.replace(/```json/g, '');\ntext = text.replace(/```/g, '');\ntext = text.trim();\n\nconst result = JSON.parse(text);\n\nreturn [{\n  json: {\n    ...$('Lead Form Submission Trigger').first().json,\n    ...result\n  }\n}];"
