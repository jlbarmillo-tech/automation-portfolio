      "parameters": {
        "promptType": "define",
        "text": "=You are a customer support escalation specialist.\n\nAnalyze the support ticket.\n\nDetermine:\n\n1. urgency\n- Low\n- Medium\n- High\n- Critical\n\n2. reason\n\nTicket Subject:\n{{ $json.Subject }}\n\nTicket Body:\n{{ $json.textPlain || $json.snippet }}\n\nUrgency Rules\n\nLow:\n- General questions\n- How-to requests\n- Non-urgent issues\n\nMedium:\n- Individual user issue\n- Workaround available\n- Limited business impact\n\nHigh:\n- Financial issue\n- Billing dispute\n- Major account problem\n- Significant customer impact\n\nCritical:\n- System outage\n- Multiple users affected\n- Security issue\n- Entire company unable to use service\n\nIMPORTANT:\n\nReturn ONLY valid JSON.\n\nExample output:\n\n{\n  \"urgency\": \"High\",\n  \"reason\": \"Customer reports incorrect billing charge.\"\n}",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        208,
        0
      ],
