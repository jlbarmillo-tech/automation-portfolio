    {
      "parameters": {
        "jsCode": "// Get file metadata from the trigger\nconst file = $('Invoice File Received').first().json;\n\n// Clean and parse Gemini's response\nlet text = $json.output;\ntext = text.replace(/```json/g, '');\ntext = text.replace(/```/g, '');\ntext = text.trim();\n\nconst invoice = JSON.parse(text);\n\nreturn [{\n  json: {\n    // File metadata\n    file_name: file.name,\n    processed_at: new Date().toISOString(),\n\n    // Extracted invoice fields\n    invoice_number: invoice.invoice_number || 'NOT FOUND',\n    invoice_date: invoice.invoice_date || 'NOT FOUND',\n    due_date: invoice.due_date || 'NOT FOUND',\n    vendor_name: invoice.vendor_name || 'NOT FOUND',\n    vendor_address: invoice.vendor_address || 'NOT FOUND',\n    client_name: invoice.client_name || 'NOT FOUND',\n    client_address: invoice.client_address || 'NOT FOUND',\n    subtotal: invoice.subtotal || 0,\n    tax_amount: invoice.tax_amount || 0,\n    total_amount: invoice.total_amount || 0,\n    payment_method: invoice.payment_method || 'NOT FOUND'\n  }\n}];"
      },
